# Copy this file to .env and edit before running docker compose up

# --- Repository ---
REPO_URL=https://github.com/StevenG916/SolarEmpireReborn.git
REPO_BRANCH=main

# --- Database ---
MYSQL_ROOT_PASSWORD=changeme_root
DB_NAME=solarempire
DB_USER=solarempire
DB_PASSWORD=changeme_db

# --- Game setup (used on first run only to seed the database) ---
SE_GAME_NAME=game1
SE_GAME_DISPLAY_NAME=Solar Empire
SE_ADMIN_PASSWORD=changeme_admin

# --- App ---
PORT=8080
SERVER_NAME=My Solar Empire Server
SEND_MAIL=0
